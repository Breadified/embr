{
  "name": "frontend",
  "version": "1.0.0",
  "main": "./index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:ci": "jest --coverage --watchAll=false --ci",
    "test:unit": "jest --testPathPattern='__tests__/(components|services|utils)'",
    "test:integration": "jest --testPathPattern='__tests__/integration'",
    "test:build": "NODE_ENV=production expo export && node scripts/validate-build.js",
    "build:development": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:production": "NODE_ENV=production eas build --profile production",
    "build:production-store": "NODE_ENV=production eas build --profile production-store",
    "build:local": "NODE_ENV=production expo export",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "deploy:production": "npm run quality:full && eas build --profile production-store",
    "quality:check": "npm run lint && npm run typecheck && npm run test:coverage",
    "quality:full": "npm run lint && npm run typecheck && npm run test:ci && npm run test:build",
    "validate:production": "npm run quality:full && npm run build:local && node scripts/validate-production.js"
  },
  "dependencies": {
    "@legendapp/state": "^2.1.15",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@supabase/supabase-js": "^2.54.0",
    "expo": "~53.0.20",
    "expo-router": "^5.1.4",
    "expo-status-bar": "~2.2.3",
    "nanoid": "^5.1.5",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-get-random-values": "^1.11.0",
    "react-native-pager-view": "^6.9.1",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-web": "^0.20.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "chance": "^1.1.13",
    "eslint": "^9.33.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "expo-build-properties": "~0.12.5",
    "jest": "^30.0.5",
    "jest-junit": "^16.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-test-renderer": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.1",
    "typescript": "~5.8.3"
  },
  "private": true
}
